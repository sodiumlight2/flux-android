<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_playlist_track_selected"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/playlist_track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Название трека"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/playlist_track_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Исполнитель"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/playlist_track_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="3:45"
        android:textSize="12sp"
        android:textColor="?android:attr/textColorTertiary"
        android:layout_marginStart="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"/>

</LinearLayout>
