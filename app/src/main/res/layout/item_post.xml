<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок поста с аватаркой -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/post_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/camera_200"
                android:scaleType="centerCrop"
                android:background="@drawable/post_item"
                android:clickable="true"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/post_author_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <ImageView
                        android:id="@+id/post_author_verified"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_verified"
                        android:visibility="gone" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/post_timestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <ImageView
                        android:id="@+id/post_device_icon"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="4dp"
                        android:layout_gravity="center_vertical"
                        android:visibility="gone"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </LinearLayout>

            <ImageButton
                android:id="@+id/post_menu_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"/>

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/post_body_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Текст поста -->
                <TextView
                    android:id="@+id/post_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:breakStrategy="balanced"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="1000"
                    android:textColor="?attr/colorOnSurface"
                    android:textIsSelectable="true"
                    android:textSize="14sp" />

                <!-- Оригинальный пост (для репостов) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/original_post_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- Заголовок оригинального поста -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <ImageView
                                android:id="@+id/original_post_avatar"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/camera_200"
                                android:scaleType="centerCrop"
                                android:background="@drawable/post_item" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/original_post_author_name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textStyle="bold"
                                        android:textSize="14sp"
                                        android:textColor="?attr/colorOnSurface"
                                        android:maxLines="1"
                                        android:ellipsize="end" />

                                    <ImageView
                                        android:id="@+id/original_post_author_verified"
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:layout_marginStart="4dp"
                                        android:layout_gravity="center_vertical"
                                        android:src="@drawable/ic_verified"
                                        android:visibility="gone" />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/original_post_timestamp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="11sp"
                                        android:textColor="?attr/colorOnSurfaceVariant" />

                                    <ImageView
                                        android:id="@+id/original_post_device_icon"
                                        android:layout_width="12dp"
                                        android:layout_height="12dp"
                                        android:layout_marginStart="4dp"
                                        android:layout_gravity="center_vertical"
                                        android:visibility="gone"
                                        app:tint="?attr/colorOnSurfaceVariant" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Область контента оригинального поста с поддержкой NSFW спойлера -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <LinearLayout
                                android:id="@+id/original_post_body_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <!-- Текст оригинального поста -->
                                <TextView
                                    android:id="@+id/original_post_content"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:textColor="?attr/colorOnSurface"
                                    android:layout_marginBottom="8dp"
                                    android:lineSpacingExtra="1dp"
                                    android:breakStrategy="balanced"
                                    android:maxLines="1000" />

                                <!-- Изображения оригинального поста -->
                                <org.nikanikoo.flux.ui.adapters.posts.PostImagesCollage
                                    android:id="@+id/original_post_images_collage"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:visibility="gone" />

                                <!-- Аудио вложения оригинального поста -->
                                <LinearLayout
                                    android:id="@+id/original_post_audio_container"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:visibility="gone"
                                    android:layout_marginBottom="8dp"/>

                                <!-- Видео вложения оригинального поста -->
                                <LinearLayout
                                    android:id="@+id/original_post_video_container"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:visibility="gone"
                                    android:layout_marginBottom="8dp"/>

                                <!-- Неподдерживаемые элементы оригинального поста -->
                                <TextView
                                    android:id="@+id/original_post_unsupported_elements"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textSize="11sp"
                                    android:textColor="@android:color/holo_orange_dark"
                                    android:textStyle="italic"
                                    android:layout_marginBottom="8dp"
                                    android:visibility="gone"
                                    android:background="#FFF3E0"
                                    android:padding="6dp"
                                    android:breakStrategy="balanced"
                                    android:maxLines="1000" />

                                <!-- Источник -->
                                <LinearLayout
                                    android:id="@+id/original_post_copyright_container"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginBottom="6dp"
                                    android:visibility="gone">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Источник: "
                                        android:textSize="11sp"
                                        android:textColor="?attr/colorOnSurfaceVariant" />

                                    <TextView
                                        android:id="@+id/original_post_copyright_link"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="11sp"
                                        android:textColor="?attr/colorPrimary"
                                        android:textStyle="bold"
                                        android:background="?attr/selectableItemBackground"
                                        android:clickable="true"
                                        android:focusable="true"/>

                                </LinearLayout>

                            </LinearLayout>

                            <!-- NSFW Спойлер для репоста -->
                            <LinearLayout
                                android:id="@+id/original_post_nsfw_spoiler"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:minHeight="120dp"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@drawable/bg_nsfw_overlay"
                                android:clickable="true"
                                android:focusable="true"
                                android:visibility="gone"
                                android:padding="12dp">

                                <!-- Чистая карточка предупреждения репоста -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:background="@drawable/bg_nsfw_spoiler"
                                    android:paddingHorizontal="18dp"
                                    android:paddingVertical="12dp">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/ic_add"
                                        app:tint="?attr/colorPrimary"
                                        android:layout_marginBottom="8dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Данный пост может содержать 18+ контент"
                                        android:textColor="#E0E0E0"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:gravity="center" />

                                </LinearLayout>

                            </LinearLayout>

                        </FrameLayout>

                        <!-- Статистика оригинального поста -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Коллаж изображений -->
                <org.nikanikoo.flux.ui.adapters.posts.PostImagesCollage
                    android:id="@+id/post_images_collage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <!-- Аудио вложения -->
                <LinearLayout
                    android:id="@+id/post_audio_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <!-- Видео вложения -->
                <LinearLayout
                    android:id="@+id/post_video_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <!-- Неподдерживаемые элементы -->
                <TextView
                    android:id="@+id/post_unsupported_elements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@android:color/holo_orange_dark"
                    android:textStyle="italic"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    android:background="#FFF3E0"
                    android:padding="8dp"
                    android:breakStrategy="balanced"
                    android:maxLines="1000" />

                <!-- Источник -->
                <LinearLayout
                    android:id="@+id/post_copyright_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Источник: "
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/post_copyright_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/nsfw_spoiler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:minHeight="140dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_nsfw_overlay"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_nsfw_spoiler"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="@color/white"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Данный пост может содержать 18+ контент"
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Действия с постом -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/post_like_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:layout_marginEnd="16dp">

                <ImageView
                    android:id="@+id/post_like_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_favorite"
                    app:tint="@color/like_inactive" />

                <TextView
                    android:id="@+id/post_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/like_inactive"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/post_comment_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:layout_marginEnd="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_comment"
                    app:tint="@android:color/darker_gray" />

                <TextView
                    android:id="@+id/post_comment_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/post_share_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_share"
                    app:tint="@android:color/darker_gray" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/share"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>