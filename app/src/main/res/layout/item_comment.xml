<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="top">

    <ImageView
        android:id="@+id/comment_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/camera_200"
        android:scaleType="centerCrop"
        android:background="@drawable/avatar_circle"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/comment_author_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Имя пользователя"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/comment_author_verified"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_verified"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:id="@+id/comment_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 мин назад"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/comment_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Текст комментария здесь"
            android:textColor="?attr/colorOnSurface"
            android:textIsSelectable="true"
            android:textSize="14sp" />

        <!-- Изображение комментария -->
        <ImageView
            android:id="@+id/comment_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:scaleType="fitStart"
            android:adjustViewBounds="true"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Аудио вложения комментария -->
        <LinearLayout
            android:id="@+id/comment_audio_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Видео вложения комментария -->
        <LinearLayout
            android:id="@+id/comment_video_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Неподдерживаемые элементы -->
        <TextView
            android:id="@+id/comment_unsupported_elements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="@android:color/holo_orange_dark"
            android:textStyle="italic"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:background="#FFF3E0"
            android:padding="6dp" />

        <!-- Действия с комментарием -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/comment_like_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/comment_like_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_favorite"
                    android:tint="@color/like_inactive" />

                <TextView
                    android:id="@+id/comment_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="12sp"
                    android:textColor="@color/like_inactive"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/comment_reply_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ответить"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackground" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>